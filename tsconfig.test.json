{
  "extends": "./tsconfig.json",
  "ts-node": {
    "esm": true,
    "experimentalSpecifierResolution": "node"
  },
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "node",
    "sourceMap": true,
    "inlineSources": true,
    "esModuleInterop": true
  },
  "include": [
    "features/**/*.ts",
    "src/**/*.ts"
  ]
}
